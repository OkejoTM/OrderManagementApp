<Window x:Class="OrderManagement.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OrderManagement.WPF.Views"
        xmlns:vm="clr-namespace:OrderManagement.WPF.ViewModels"
        Title="Управление заказами" Width="1000" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Icon="/app.ico">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:AddressListViewModel}">
            <views:AddressListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AddressHistoryViewModel}">
            <views:AddressHistoryView/>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding NavigationService.CurrentView}"/>
</Window>