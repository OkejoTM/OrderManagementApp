<Window x:Class="OrderManagement.WPF.Views.Dialogs.AddressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="450" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <StackPanel Margin="24">
        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"
                   Foreground="#1E293B" Margin="0,0,0,16"/>

        <TextBlock Text="Название адреса:" Margin="0,0,0,6" Foreground="#475569"/>

        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    IsDefault="True"/>
            <Button Content="Отмена"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>